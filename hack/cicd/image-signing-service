pipeline {
    agent { label 'onprem-ai-services-stelar-machine' }
    
    parameters {
        string(
            name: 'VERSION',
            description: 'Version to sign (e.g., v0.2.0-rc.1)'
        )
        string(
            name: 'ICR_REGISTRY',
            defaultValue: 'icr.io/ai-services-cicd',
            description: 'Registry where images will be pushed'
        )
    }
    
    environment {
        // Directory paths
        CERT_DIR = "/tmp/certs"
        PUBLIC_ARTIFACTS_DIR = "/tmp/public-artifacts"
        DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR = '/home/jenkins/public-artifacts'
        HOME_DIR = '/home/jenkins'
        REPO_DIR = 'project-ai-services'
        
        // Credentials
        PFX_CREDS = credentials('pfx-credentials')
        
        // Registry configuration
        REGISTRY = 'docker-na.artifactory.swg-devops.com'
        AI_SERVICES_REPO_URL = 'https://github.com/IBM/project-ai-services.git'
        
        // Garasign configuration
        GARASIGN_CLIENT = '/opt/Garantir/bin/garasign'
        GARASIGN_MODULE_PATH = '/usr/local/lib/Garantir/GRS/libgrsp11.so'
        GARASIGN_SLOT_ID = '1'
    }
    
    stages {
        stage('Initialize') {
            steps {
                script {
                    validateVersion()
                    deleteDir()
                }
            }
        }
        
        stage('Checkout') {
            steps {
                script {
                    checkoutRepository()
                }
            }
        }

        stage('Build chatbot service') {
            steps {
                script {
                    env.ICR_SERVICES_CHATBOT_IMAGE = buildAndPublishImage('services/chatbot/', 'chatbot-service')
                }
            }
        }

        stage('Build digitize service') {
            steps {
                script {
                    env.ICR_SERVICES_DIGITIZE_IMAGE = buildAndPublishImage('services/digitize/', 'digitize-service')
                }
            }
        }

        stage('Build summarize service') {
            steps {
                script {
                    env.ICR_SERVICES_SUMMARIZE_IMAGE = buildAndPublishImage('services/summarize/', 'summarize-service')
                }
            }
        }

        stage('Build similarity service') {
            steps {
                script {
                    env.ICR_SERVICES_SIMILARITY_IMAGE = buildAndPublishImage('services/similarity/', 'similarity-service')
                }
            }
        }

        stage('Build service-base') {
            steps {
                script {
                    env.ICR_SERVICE_BASE_IMAGE = buildAndPublishImage('images/service-base/', 'service-base')
                }
            }
        }

        stage('Build Caddy') {
            steps {
                script {
                    env.ICR_CADDY_IMAGE = buildAndPublishImage('images/caddy/', 'caddy')
                }
            }
        }

        stage('Build litellm') {
            steps {
                script {
                    env.ICR_LITELLM_IMAGE = buildAndPublishImage('images/litellm/', 'litellm')
                }
            }
        }

        stage('Build postgres') {
            steps {
                script {
                    env.ICR_POSTGRES_IMAGE = buildAndPublishImage('images/postgres/', 'postgres')
                }
            }
        }

        stage('Build Tools AMD64') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    sh 'rm -rf project-ai-services'
                    checkoutRepository()
                    env.ICR_TOOL_IMAGE_AMD = buildAndPublishImage('images/tools/', 'tools')
                }
            }
        }

        stage('Build Tools ARM64') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    env.ICR_TOOL_IMAGE_ARM = buildToolArmImage('images/tools/', 'tools')
                }
            }
        }

        stage('Build Tools PPC64LE') {
            steps {
                script {
                    env.ICR_TOOL_IMAGE_PPC64LE = buildAndPublishImage('images/tools/', 'tools')
                }
            }
        }

        stage('Create Tools Manifest') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    env.ICR_TOOL_IMAGE = createToolsManifest()
                }
            }
        }

        stage('Build AI Services') {
            steps {
                script {
                    env.ICR_AI_SERVICES_IMAGE = buildAndPublishImage('ai-services', 'ai-services')
                }
            }
        }

        stage('Build UI Catalog') {
            steps {
                script {
                    env.ICR_UI_CATALOG_IMAGE = buildAndPublishImage('ui/catalog', 'catalog-ui')
                }
            }
        }

        stage('Build UI Digitize') {
            steps {
                script {
                    env.ICR_UI_DIGITIZE_IMAGE = buildAndPublishImage('ui/digitize', 'digitize-ui')
                }
            }
        }
        stage('Build UI Chatbot') {
            steps {
                script {
                    env.ICR_UI_CHATBOT_IMAGE = buildAndPublishImage('ui/chatbot', 'chatbot-ui')
                }
            }
        }

        stage('Setup Certificates') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    setupCerts()
                }
            }
        }

        stage('Generate Image List') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    generateImageList()
                }
            }
        }

        stage('Code Signing Agent') {
            agent {
                docker {
                    label 'shared-x86-centos9'
                    image "${env.REGISTRY}/taas-docker-public/jonk/agent-jnlp:latest"
                    registryCredentialsId 'jfrog'
                    registryUrl "https://${env.REGISTRY}"
                    args """
                    -e VERSION=${params.VERSION} \
                    -e CODE_SIGNING_PFX_FILE=${env.HOME_DIR}/certs/cert.pfx \
                    -e CODE_SIGNING_P12_PASSWORD=${PFX_CREDS} \
                    -v ${CERT_DIR}:${env.HOME_DIR}/certs:z \
                    -v ${PUBLIC_ARTIFACTS_DIR}:${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}:z
                    """
                }
            }

            stages {
                stage('Initialize Garasign') {
                    steps {
                        script {
                            initializeGaraClient()
                        }
                    }
                }

                stage('Export Certificates') {
                    steps {
                        script {
                            exportPublicCertificates()
                        }
                    }
                }

                stage('Sign Images') {
                    steps {
                        script {
                            cosignLogin()
                            signImages()
                        }
                    }
                }
            }
        }

        stage('Upload Artifacts') {
            agent { label 'shared-x86-centos9' }
            steps {
                script {
                    uploadArtifacts()
                }
            }
        }
    }
    
    post {
        always {
            script {
                cleanup()
            }
        }
        success {
            echo "✓ Image signing pipeline completed successfully for version ${params.VERSION}"
        }
        failure {
            echo "✗ Image signing pipeline failed for version ${params.VERSION}"
        }
    }
}

def validateVersion() {
    if (!params.VERSION) {
        error('VERSION parameter is required')
    }

    echo "Validating version: ${params.VERSION}"

    def tags = sh(
        script: "git ls-remote --tags ${env.AI_SERVICES_REPO_URL} | cut -d/ -f3",
        returnStdout: true
    ).trim()

    if (!tags.contains(params.VERSION)) {
        error "Failed to find tag ${params.VERSION} in repository"
    }

    echo "✓ Version ${params.VERSION} validated successfully"
}


def checkoutRepository() {
    echo "Checking out repository at version ${params.VERSION}..."

    sh """
        rm -rf ${env.REPO_DIR}
        git clone ${env.AI_SERVICES_REPO_URL}
        cd ${env.REPO_DIR}
        git checkout ${params.VERSION}
        ls -lrt
    """

    echo "✓ Repository checked out successfully"
}


def buildAndPublishImage(String imagePath, String imageName) {
    def icrImage = ''
    if (imagePath.startsWith('services/')) {
        def serviceName = imagePath.split('/')[1]
        dir("${REPO_DIR}/services") {
            echo "Building and pushing ${imageName} image (service: ${serviceName})..."
            def tag = sh(script: "make image-tag SERVICE=${serviceName}", returnStdout: true).trim()
            icrImage = "${params.ICR_REGISTRY}/${imageName}:${tag}"
            withCredentials([usernamePassword(
                credentialsId: 'icr-iam-creds',
                usernameVariable: 'ICR_USERNAME',
                passwordVariable: 'ICR_PASSWORD'
            )]) {
                sh """
                    make build SERVICE=${serviceName} REGISTRY=${params.ICR_REGISTRY} \\
                        REGISTRY_USER=\$ICR_USERNAME \\
                        REGISTRY_PASSWORD=\$ICR_PASSWORD
                    make push SERVICE=${serviceName} REGISTRY=${params.ICR_REGISTRY} \\
                        REGISTRY_USER=\$ICR_USERNAME \\
                        REGISTRY_PASSWORD=\$ICR_PASSWORD
                """
            }
            echo "✓ Successfully built and pushed: ${icrImage}"
        }
    } else {
        dir("${REPO_DIR}/${imagePath}") {
            echo "Building and pushing ${imageName} image..."
            def tag = sh(script: "make image-tag", returnStdout: true).trim()
            icrImage = "${params.ICR_REGISTRY}/${imageName}:${tag}"
            withCredentials([usernamePassword(
                credentialsId: 'icr-iam-creds',
                usernameVariable: 'ICR_USERNAME',
                passwordVariable: 'ICR_PASSWORD'
            )]) {
                sh """
                    make build REGISTRY=${params.ICR_REGISTRY} \\
                        REGISTRY_USER=\$ICR_USERNAME \\
                        REGISTRY_PASSWORD=\$ICR_PASSWORD
                    make push REGISTRY=${params.ICR_REGISTRY} \\
                        REGISTRY_USER=\$ICR_USERNAME \\
                        REGISTRY_PASSWORD=\$ICR_PASSWORD
                """
            }
            echo "✓ Successfully built and pushed: ${icrImage}"
        }
    }
    return icrImage
}

def buildToolArmImage(String imagePath, String imageName) {
    def icrImage = ''
    dir("${REPO_DIR}/${imagePath}") {
        echo "Building ARM64 ${imageName} image..."

        def toolVersion = sh(
            script: "awk -F '=' '/TAG\\?/{print \$2}' Makefile",
            returnStdout: true
        ).trim()
        def tag = "${toolVersion}-arm64"
        icrImage = "${params.ICR_REGISTRY}/${imageName}:${tag}"

        withCredentials([usernamePassword(
            credentialsId: 'icr-iam-creds',
            usernameVariable: 'ICR_USERNAME',
            passwordVariable: 'ICR_PASSWORD'
        )]) {
            // Setup buildx for multi-arch builds
            sh """
                docker run --privileged --rm docker.io/tonistiigi/binfmt --install all
                docker buildx rm multiarch || true
                docker buildx create --name multiarch --driver docker-container --use
                docker buildx inspect --bootstrap
            """
            
            // Create Docker config for authentication
            sh '''
                AUTH=\$(printf "%s" "\$ICR_USERNAME:\$ICR_PASSWORD" | base64)
                cat > ${WORKSPACE}/config.json <<EOF
{"auths":{"icr.io":{"auth":"\$AUTH"}}}
EOF
            '''
            
            // Build and push ARM64 image
            sh """
                DOCKER_CONFIG=${WORKSPACE} docker buildx build \
                    --platform linux/arm64 \
                    --rm \
                    -t ${params.ICR_REGISTRY}/${imageName}:${tag} \
                    --provenance=false \
                    -f Containerfile \
                    . \
                    --push
            """
        }
        
        echo "✓ Successfully built and pushed ARM64: ${icrImage}"
    }
    return icrImage
}

def createToolsManifest() {
    def manifestImage = ''
    dir("${REPO_DIR}/images/tools/") {
        echo "Creating multi-arch manifest for tools image..."

        withCredentials([usernamePassword(
            credentialsId: 'icr-iam-creds',
            usernameVariable: 'ICR_USERNAME',
            passwordVariable: 'ICR_PASSWORD'
        )]) {
            sh """
                make manifest \
                    REGISTRY=${params.ICR_REGISTRY} \
                    REGISTRY_USER=\$ICR_USERNAME \
                    REGISTRY_PASSWORD=\$ICR_PASSWORD
            """

            def tag = sh(
                script: "awk -F '=' '/TAG\\?/{print \$2}' Makefile",
                returnStdout: true
            ).trim()
            manifestImage = "${params.ICR_REGISTRY}/tools:${tag}"

            echo "✓ Created manifest: ${manifestImage}"
        }
    }
    return manifestImage
}

def setupCerts() {
    echo "Setting up certificate directory..."

    sh """
        mkdir -p ${env.CERT_DIR}
        mkdir -p ${env.PUBLIC_ARTIFACTS_DIR}
    """

    withCredentials([
        file(credentialsId: 'garasign-pfx-cert', variable: 'PFX_CERT')
    ]) {
        sh """
            cp \${PFX_CERT} ${env.CERT_DIR}/cert.pfx
            chmod 600 ${env.CERT_DIR}/cert.pfx
        """
    }

    echo "✓ Certificates prepared successfully"
}

def generateImageList() {
    echo "Generating image list for signing..."

    def images = [
        env.ICR_SERVICES_CHATBOT_IMAGE,
        env.ICR_SERVICES_DIGITIZE_IMAGE,
        env.ICR_SERVICES_SUMMARIZE_IMAGE,
        env.ICR_SERVICES_SIMILARITY_IMAGE,
        env.ICR_UI_CATALOG_IMAGE,
        env.ICR_UI_DIGITIZE_IMAGE,
        env.ICR_UI_CHATBOT_IMAGE,
        env.ICR_SERVICE_BASE_IMAGE,
        env.ICR_CADDY_IMAGE,
        env.ICR_LITELLM_IMAGE,
        env.ICR_POSTGRES_IMAGE,
        env.ICR_TOOL_IMAGE,
        env.ICR_AI_SERVICES_IMAGE     
    ]

    def imageList = images.join('\n')


    dir("${CERT_DIR}") {
        writeFile file: 'images.txt', text: imageList
        sh 'cat images.txt'
    }

    echo "✓ Image list generated with ${images.size()} images"
}

def cosignLogin() {
    echo 'Logging into ICR for Cosign...'
    
    withCredentials([usernamePassword(
        credentialsId: 'icr-iam-creds',
        usernameVariable: 'ICR_USERNAME',
        passwordVariable: 'ICR_PASSWORD'
    )]) {
        sh 'cosign login icr.io -u \$ICR_USERNAME -p \$ICR_PASSWORD'
    }

    echo '✓ Cosign login successful'
}

def initializeGaraClient() {
    echo 'Initializing Garasign client...'

    sh """
        setup-garasign-client
        cp ${env.HOME_DIR}/.config/Garantir/GRS/config.ini /root/.config/Garantir/GRS/config.ini
        GrsGPGLoader
        garasign listkeys
    """

    echo '✓ Garasign initialized successfully'
}

def exportPublicCertificates() {
    echo 'Exporting public certificates...'

    def keys = sh(
        script: "\$GARASIGN_CLIENT listkeys | grep -i PRD | awk 'NR==1{print \$8}'",
        returnStdout: true
    ).trim()

    if (!keys) {
        error 'Failed to retrieve Garasign key'
    }

    env.KEYS = keys
    echo "Using Garasign key: ${env.KEYS}"

    sh """
        \$GARASIGN_CLIENT export \
            --key \${KEYS} \
            --outputDirectory \${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}

        mv \${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}/\${KEYS}.pem.pub.key \
           \${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}/cosign.pub

        ls -lrt \${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}
    """

    echo '✓ Public certificates exported successfully'
}

def signImages() {
    echo "Signing images with Cosign..."
    
    sh """
        set +x  # Disable command echoing for sensitive operations
        
        # Retrieve PKCS11 token
        pkc_token=\$(cosign pkcs11-tool list-keys-uris \
            --module-path ${env.GARASIGN_MODULE_PATH} \
            --slot-id ${env.GARASIGN_SLOT_ID} 2>/dev/null | \
            grep pkcs11 | awk '{print \$2}')
        
        if [ -z "\$pkc_token" ]; then
            echo "ERROR: Failed to retrieve PKCS11 token URI"
            exit 1
        fi
        
        echo "✓ PKCS11 token retrieved successfully"
        
        # Sign each image
        while IFS= read -r image; do
            if [ -n "\$image" ]; then
                echo "Signing image: \$image"
                cosign sign \
                    --key \$pkc_token \
                    --tlog-upload=false \
                    -r \
                    --cert-chain ${DOCKER_AGENT_PUBLIC_ARTIFACTS_DIR}/\${KEYS}.pem.chain \
                    \$image
            fi
        done < ${HOME_DIR}/certs/images.txt
        
        echo "✓ All images signed successfully"
    """
}

def uploadArtifacts() {
    echo 'Uploading signed artifacts...'

    sh "ls -lrt ${env.PUBLIC_ARTIFACTS_DIR}"

    dir("${PUBLIC_ARTIFACTS_DIR}") {
        sh "rm -rf PRD*"
        archiveArtifacts(
            artifacts: '**/*',
            fingerprint: true,
            allowEmptyArchive: false
        )
    }

    echo '✓ Artifacts uploaded successfully'
}

def cleanup() {
    echo "Cleaning up temporary directories..."

    sh """
        rm -rf ${env.CERT_DIR} || true
        rm -rf ${env.PUBLIC_ARTIFACTS_DIR} || true
    """

    echo '✓ Cleanup completed'
}
