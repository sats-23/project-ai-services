apiVersion: v1
kind: Pod
metadata:
  name: "{{ .AppName }}--digitize"
  labels:
    ai-services.io/application: "{{ .AppName }}"
    ai-services.io/template: "{{ .AppTemplateName }}"
    ai-services.io/version: "{{ .Version }}"
  annotations:
    ai-services.io/ports: "{{ .Values.digitizeUi.port }}:4001, {{ .Values.digitize.port }}:4000"
    io.podman.annotations.pids-limit/backend-server: "4096"
spec:
  containers:
    - name: ui
      image: "{{ .Values.digitizeUi.image }}"
      resources:
        requests:
          memory: "512Mi"
        limits:
          memory: "512Mi"
      env:
        - name: BACKEND_HOST
          value: "{{ .AppName }}--digitize"
        - name: BACKEND_PORT
          value: "4000"
      ports:
        - containerPort: 4001
          protocol: TCP
      livenessProbe:
        httpGet:
          path: /
          port: 4001
        initialDelaySeconds: 10
        periodSeconds: 30
        timeoutSeconds: 5
        failureThreshold: 3
    - name: backend-server
      image: "{{ .Values.digitize.image }}"
      command:
        - "/var/venv/bin/python"
        - "-m"
        - "uvicorn"
        - "digitize.app:app"
        - "--host"
        - "0.0.0.0"
        - "--port"
        - "4000"
        - "--loop"
        - "uvloop"
        - "--http"
        - "httptools"
      ports:
        - containerPort: 4000
          name: http
      livenessProbe:
        httpGet:
          path: /health
          port: 4000
        initialDelaySeconds: 30
        periodSeconds: 10
        timeoutSeconds: 5
        failureThreshold: 3
      resources:
        requests:
          memory: "50Gi"
        limits:
          memory: "50Gi"
      env:
        - name: EMB_ENDPOINT
          value: "http://{{ .AppName }}--vllm-server:8001"
        - name: EMB_MODEL
          value: "ibm-granite/granite-embedding-278m-multilingual"
        - name: EMB_MAX_TOKENS
          value: "512"
        - name: LLM_ENDPOINT
          value: "http://{{ .AppName }}--vllm-server:8000"
        - name: LLM_MODEL
          value: "ibm-granite/granite-3.3-8b-instruct"
        - name: OPENSEARCH_HOST
          value: "{{ .AppName }}--opensearch"
        - name: OPENSEARCH_PORT
          value: "9200"
        - name: OPENSEARCH_DB_PREFIX
          value: "RAG_DB"
        - name: OPENSEARCH_INDEX_NAME
          value: "RAG_INDEX"
        - name: OPENSEARCH_USERNAME
          value: "{{ .Values.opensearch.auth.username }}"
        - name: OPENSEARCH_PASSWORD
          value: "{{ .Values.opensearch.auth.password }}"
        - name: LOG_LEVEL
          value: "{{ .Values.digitize.log_level }}"
      volumeMounts:
        - mountPath: /var/cache:z
          name: cache
  restartPolicy: Always
  volumes:
    - name: cache
      hostPath:
        path: "/var/lib/ai-services/applications/{{ .AppName }}/cache"
        type: DirectoryOrCreate
