apiVersion: v1
kind: Pod
metadata:
  name: "{{ .AppName }}--digitize"
  labels:
    ai-services.io/application: "{{ .AppName }}"
    ai-services.io/template: "{{ .AppTemplateName }}"
    ai-services.io/version: "{{ .Version }}"
  annotations:
    ai-services.io/ports: "{{ .Values.digitizeUi.port }}:4001, {{ .Values.digitize.port }}:4000"
    io.podman.annotations.pids-limit/backend-server: "4096"
spec:
  initContainers:
    - name: digitize-db-init
      image: "{{ .Values.digitize.image }}"
      command: ["/var/venv/bin/python", "db/scripts/init_db.py"]
      env:
        - name: POSTGRES_HOST
          value: "{{ .AppName }}--postgres"
        - name: POSTGRES_PORT
          value: "5432"
        - name: POSTGRES_DB
          value: "{{ .Values.digitize.database }}"
        - name: POSTGRES_USER
          value: "postgres"
        - name: POSTGRES_PASSWORD
          value: "{{ .Values.postgres.password }}"
  containers:
    - name: ui
      image: "{{ .Values.digitizeUi.image }}"
      resources:
        requests:
          memory: "512Mi"
        limits:
          memory: "512Mi"
      env:
        - name: BACKEND_HOST
          value: "{{ .AppName }}--digitize"
        - name: BACKEND_PORT
          value: "4000"
      ports:
        - containerPort: 4001
          protocol: TCP
      livenessProbe:
        httpGet:
          path: /
          port: 4001
        initialDelaySeconds: 10
        periodSeconds: 30
        timeoutSeconds: 5
        failureThreshold: 3
    - name: backend-server
      image: "{{ .Values.digitize.image }}"
      command:
        - "tail"
        - "-f"
        - "/dev/null"
      ports:
        - containerPort: 4000
          name: http
      resources:
        requests:
          memory: "50Gi"
        limits:
          memory: "50Gi"
      env:
        - name: POSTGRES_HOST
          value: "{{ .AppName }}--postgres"
        - name: POSTGRES_PORT
          value: "5432"
        - name: POSTGRES_DB
          value: "{{ .Values.digitize.database }}"
        - name: POSTGRES_USER
          value: "postgres"
        - name: POSTGRES_PASSWORD
          value: "{{ .Values.postgres.password }}"
        - name: DB_POOL_SIZE
          value: "5"
        - name: DB_MAX_OVERFLOW
          value: "5"
        - name: EMB_ENDPOINT
          value: "http://{{ .AppName }}--vllm-server:8001"
        - name: EMB_MODEL
          value: "{{ .Values.embedding.model.name }}"
        - name: EMB_MAX_MODEL_LEN
          value: "{{ .Values.embedding.model.maxModelLen }}"
        - name: LLM_ENDPOINT
          value: "http://{{ .AppName }}--vllm-server:8000"
        - name: LLM_MODEL
          value: "{{ .Values.instruct.model.name }}"
        - name: LLM_MAX_MODEL_LEN
          value: "{{ .Values.instruct.model.maxModelLen }}"
        - name: LLM_MAX_BATCH_SIZE
          value: "{{ .Values.instruct.model.maxBatchSize }}"
        - name: OPENSEARCH_HOST
          value: "{{ .AppName }}--opensearch"
        - name: OPENSEARCH_PORT
          value: "9200"
        - name: OPENSEARCH_DB_PREFIX
          value: "RAG_DB"
        - name: OPENSEARCH_INDEX_NAME
          value: "RAG_INDEX"
        - name: OPENSEARCH_USERNAME
          value: "{{ .Values.opensearch.auth.username }}"
        - name: OPENSEARCH_PASSWORD
          value: "{{ .Values.opensearch.auth.password }}"
        - name: OPENSEARCH_NUM_SHARDS
          value: "1"
        - name: LOG_LEVEL
          value: "{{ .Values.digitize.log_level }}"
        {{- if .Values.instruct.apiKey }}
        - name: LLM_API_KEY
          value: "{{ .Values.instruct.apiKey }}"
        {{- end }}
      volumeMounts:
        - mountPath: /var/cache:z
          name: cache
  restartPolicy: Always
  volumes:
    - name: cache
      hostPath:
        path: "{{ .BaseDir }}/applications/{{ .AppName }}/cache"
        type: DirectoryOrCreate
